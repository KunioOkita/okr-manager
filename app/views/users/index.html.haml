%h1 Listing users

%table.table.table-striped
  %thead
    %tr
      %th{scope: "col"} Provider
      %th Uid
      %th Name
      %th Mail
      %th Image url
      %th
      %th
      %th

  %tbody
    - @users.each do |user|
      %tr
        %td= user.provider
        %td= user.uid
        %td= user.name
        %td= user.mail
        %td= user.image_url
        %td= link_to 'Show', user
        %td= link_to 'Destroy', user, method: :delete, data: { confirm: 'Are you sure?' }

%br
